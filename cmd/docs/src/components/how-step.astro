---
const props = Astro.props;
const { number } = props;
---

<div class="flex items-center gap-3 py-2.5 border-b border-border last:border-b-0">
  <span class="font-mono text-[10.5px] font-bold text-white bg-primary size-5 rounded-full inline-flex items-center justify-center shrink-0">
    {number}
  </span>
  <div>
    <slot />
  </div>
</div>
