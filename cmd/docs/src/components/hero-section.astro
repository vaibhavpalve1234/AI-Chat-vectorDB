---
import CopyButton from './copy-button.astro';

const installCmd = 'curl -sL https://slim.sh/install.sh | sh';
---

<section class="relative py-20 text-left max-sm:py-12 overflow-hidden" id="install">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_0%,_hsl(210_40%_14%)_0%,_transparent_60%)] pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-(--max-width) mx-auto px-(--padding-x) text-center relative">
    <div class="inline-flex items-center gap-2 rounded-full bg-[hsl(0_0%_100%/6%)] px-3.5 py-1.5 text-[11.5px] font-medium text-text-secondary mb-6">
      <span class="size-1.5 rounded-full bg-primary"></span>
      Free Forever &nbsp; · &nbsp; Built with Go
    </div>

    <h1 class="font-heading text-[44px] font-medium leading-[1.12] tracking-[-0.03em] text-text max-sm:text-[28px]">
      Give your localhost a<br /><span class="text-[#34d399]">local</span> or <span class="text-[#a78bfa]">public</span> URL
    </h1>
    <p class="text-[15px] leading-[1.6] text-text-secondary mt-6 mb-8 max-w-115 max-sm:text-sm mx-auto">
      Turn <code class="bg-[hsl(0_0%_100%/8%)] px-1.5 py-0.5 rounded text-[13px] text-text">localhost:3000</code> into <code class="bg-[hsl(0_0%_100%/8%)] px-1.5 py-0.5 rounded text-[13px] text-text">https://app.test</code> with path routing, HTTPS, HMR support, or get a public url without deployment.
    </p>

    <div class="flex gap-0 mb-0">
      <button
        class="hero-tab rounded-t-lg px-4 py-2 text-[13px] font-medium transition-colors bg-code-bg text-white"
        data-hero-tab="local"
        type="button"
      >Local Domains</button>
      <button
        class="hero-tab rounded-t-lg px-4 py-2 text-[13px] font-medium transition-colors bg-[#232323] text-text-tertiary hover:text-text-secondary"
        data-hero-tab="share"
        type="button"
      >Internet Sharing</button>
    </div>

    <div class="rounded-b-[10px] rounded-tr-[10px] bg-code-bg text-left overflow-hidden shadow-[0_4px_24px_rgba(0,0,0,0.3)]">
      <div class="flex gap-1.5 border-b border-[#1a1a1a] px-3.5 py-2.5">
        <span class="size-2.5 rounded-full bg-[#ff5f57]"></span>
        <span class="size-2.5 rounded-full bg-[#febc2e]"></span>
        <span class="size-2.5 rounded-full bg-[#28c840]"></span>
      </div>

      <div class="hero-panel" data-hero-panel="local">
        <div class="px-4 pt-4 pb-5 font-mono text-[13px] leading-[1.7] text-code-text max-sm:text-[11.5px]">
          <div class="flex gap-2">
            <span class="text-[#10b981] select-none">$</span>
            <span><span class="text-[#7dd3fc]">slim</span> start web <span class="text-[#60a5fa]">--port</span> <span class="text-[#fbbf24]">3000</span></span>
          </div>
          <div class="pl-4 whitespace-nowrap">
            <span class="text-[#34d399]">&#10003;</span> <span class="text-[#34d399] font-medium">https://web.test</span> <span class="text-[#525252]">&rarr;</span> <span class="text-[#737373]">localhost:3000</span>
          </div>

          <div class="flex gap-2 mt-3">
            <span class="text-[#10b981] select-none">$</span>
            <span><span class="text-[#7dd3fc]">slim</span> start myapp <span class="text-[#60a5fa]">--port</span> <span class="text-[#fbbf24]">3000</span> <span class="text-[#60a5fa]">--route</span> <span class="text-[#fbbf24]">/api=8080</span></span>
          </div>
          <div class="pl-4 whitespace-nowrap">
            <span class="text-[#34d399]">&#10003;</span> <span class="text-[#34d399] font-medium">https://myapp.test</span> &nbsp;&nbsp;&nbsp;<span class="text-[#525252]">&rarr;</span> <span class="text-[#737373]">localhost:3000</span>
          </div>
          <div class="pl-4 whitespace-nowrap">
            <span class="text-[#737373]">&nbsp;</span> <span class="text-[#fbbf24]">https://myapp.test/api</span> <span class="text-[#525252]">&rarr;</span> <span class="text-[#737373]">localhost:8080</span>
          </div>

          <div class="flex gap-2 mt-3">
            <span class="text-[#10b981] select-none">$</span>
            <span><span class="text-[#7dd3fc]">slim</span> start app.loc <span class="text-[#60a5fa]">--port</span> <span class="text-[#fbbf24]">4000</span></span>
          </div>
          <div class="pl-4 whitespace-nowrap">
            <span class="text-[#34d399]">&#10003;</span> <span class="text-[#34d399] font-medium">https://app.loc</span> <span class="text-[#525252]">&rarr;</span> <span class="text-[#737373]">localhost:4000</span>
          </div>

          <div class="flex gap-2 mt-3">
            <span class="text-[#10b981] select-none">$</span>
            <span><span class="text-[#7dd3fc]">slim</span> up <span class="text-[#525252]">&nbsp;# .slim.yaml</span></span>
          </div>
          <div class="pl-4 whitespace-nowrap">
            <span class="text-[#34d399]">&#10003;</span> <span class="text-[#34d399] font-medium">https://myapp.test</span> &nbsp;&nbsp;&nbsp;<span class="text-[#525252]">&rarr;</span> <span class="text-[#737373]">localhost:3000</span>
          </div>
          <div class="pl-4 whitespace-nowrap">
            <span class="text-[#737373]">&nbsp;</span> <span class="text-[#fbbf24]">https://myapp.test/api</span> <span class="text-[#525252]">&rarr;</span> <span class="text-[#737373]">localhost:8080</span>
          </div>
          <div class="pl-4 whitespace-nowrap">
            <span class="text-[#34d399]">&#10003;</span> <span class="text-[#34d399] font-medium">https://dashboard.test</span> <span class="text-[#525252]">&rarr;</span> <span class="text-[#737373]">localhost:5173</span>
          </div>
        </div>
      </div>

      <div class="hero-panel hidden" data-hero-panel="share">
        <div class="px-4 pt-4 pb-5 font-mono text-[13px] leading-[1.7] text-code-text max-sm:text-[11.5px]">
          <div class="flex gap-2">
            <span class="text-[#10b981] select-none">$</span>
            <span><span class="text-[#7dd3fc]">slim</span> share <span class="text-[#60a5fa]">--port</span> <span class="text-[#fbbf24]">3000</span></span>
          </div>
          <div class="pl-4 whitespace-nowrap">
            <span class="text-[#34d399]">&#10003;</span> <span class="text-[#34d399] font-medium">https://r4nd0m.slim.show</span> <span class="text-[#525252]">&rarr;</span> <span class="text-[#737373]">localhost:3000</span>
          </div>

          <div class="flex gap-2 mt-3">
            <span class="text-[#10b981] select-none">$</span>
            <span><span class="text-[#7dd3fc]">slim</span> share <span class="text-[#60a5fa]">--port</span> <span class="text-[#fbbf24]">3000</span> <span class="text-[#60a5fa]">--subdomain</span> <span class="text-[#fbbf24]">demo</span></span>
          </div>
          <div class="pl-4 whitespace-nowrap">
            <span class="text-[#34d399]">&#10003;</span> <span class="text-[#34d399] font-medium">https://demo.slim.show</span> <span class="text-[#525252]">&rarr;</span> <span class="text-[#737373]">localhost:3000</span>
          </div>

          <div class="flex gap-2 mt-3">
            <span class="text-[#10b981] select-none">$</span>
            <span><span class="text-[#7dd3fc]">slim</span> share <span class="text-[#60a5fa]">--port</span> <span class="text-[#fbbf24]">8080</span> <span class="text-[#60a5fa]">--password</span> <span class="text-[#60a5fa]">--ttl</span> <span class="text-[#fbbf24]">30m</span></span>
          </div>
          <div class="pl-4 whitespace-nowrap">
            <span class="text-[#34d399]">&#10003;</span> <span class="text-[#34d399] font-medium">https://a1b2c3.slim.show</span> <span class="text-[#525252]">&rarr;</span> <span class="text-[#737373]">localhost:8080</span>
          </div>
          <div class="pl-4 whitespace-nowrap">
            <span class="text-[#737373]">&nbsp;</span> <span class="text-[#60a5fa]">password protected</span> <span class="text-[#525252]">&middot;</span> <span class="text-[#fbbf24]">expires in 30m</span>
          </div>

          <div class="flex gap-2 mt-3">
            <span class="text-[#10b981] select-none">$</span>
            <span><span class="text-[#7dd3fc]">slim</span> share <span class="text-[#60a5fa]">--port</span> <span class="text-[#fbbf24]">4321</span> <span class="text-[#60a5fa]">--subdomain</span> <span class="text-[#fbbf24]">staging</span> <span class="text-[#60a5fa]">--ttl</span> <span class="text-[#fbbf24]">2h</span></span>
          </div>
          <div class="pl-4 whitespace-nowrap">
            <span class="text-[#34d399]">&#10003;</span> <span class="text-[#34d399] font-medium">https://staging.slim.show</span> <span class="text-[#525252]">&rarr;</span> <span class="text-[#737373]">localhost:4321</span>
          </div>
          <div class="pl-4 whitespace-nowrap">
            <span class="text-[#737373]">&nbsp;</span> <span class="text-[#fbbf24]">expires in 2h</span>
          </div>
        </div>
      </div>
    </div>

    <div class="text-left mt-7">
      <p class="text-[13px] text-text font-medium mb-2">Install with one command</p>
      <div class="bg-code-bg rounded-lg px-4 py-2.5 flex items-center gap-3 overflow-x-auto">
        <code class="font-mono text-[12.5px] text-[#a3a3a3] whitespace-nowrap flex-1">
          <span class="text-[#10b981] mr-1.5">$</span> <span class="text-[#7dd3fc]">curl</span> <span class="text-[#60a5fa]">-sL</span> <span class="text-[#34d399]">https://slim.sh/install.sh</span> | <span class="text-[#7dd3fc]">sh</span>
        </code>
        <CopyButton text={installCmd} />
      </div>
      <p class="text-[12.5px] text-text-tertiary mt-2 leading-normal">
        Or <a href="https://github.com/kamranahmedse/slim#build-from-source" class="text-text-tertiary underline underline-offset-2 transition-colors hover:text-text-secondary">build from source</a>.
      </p>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.hero-tab').forEach(function (tab) {
    tab.addEventListener('click', function () {
      var target = tab.getAttribute('data-hero-tab');

      document.querySelectorAll('.hero-tab').forEach(function (t) {
        t.classList.remove('bg-code-bg', 'text-white', 'hover:text-white');
        t.classList.add('bg-[#232323]', 'text-text-tertiary');
      });
      tab.classList.remove('bg-[#232323]', 'text-text-tertiary');
      tab.classList.add('bg-code-bg', 'text-white', 'hover:text-white');

      document.querySelectorAll('.hero-panel').forEach(function (p) {
        p.classList.add('hidden');
      });
      var panel = document.querySelector('.hero-panel[data-hero-panel="' + target + '"]');
      if (panel) {
        panel.classList.remove('hidden');
      }
    });
  });
</script>
